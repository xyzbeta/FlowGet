<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="220"
             xmlns:windows="using:FlowGet.ViewModels.Windows"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:DataType="windows:MediaWindowViewModel"
             x:Class="FlowGet.Views.Windows.MediaWindowView">

    <Border CornerRadius="8" Padding="20,16"
            Background="{DynamicResource MaterialCardBackgroundBrush}">
        <Grid ColumnDefinitions="*,auto" Name="mediaDownloadInfoGrid"
              DataContext="{Binding MediaDownloadInfo}">
            <StackPanel Spacing="10">
                <!-- 视频地址 -->
                <Grid ColumnDefinitions="auto,*">
                    <ComboBox SelectedIndex="{Binding StreamIndex}" Width="90" FontSize="14">
                        <ComboBox.Styles>
                            <Style Selector="ComboBox /template/ Panel#PART_RootPanel > Grid">
                                <Setter Property="VerticalAlignment" Value="Bottom" />
                            </Style>
                        </ComboBox.Styles>
                        <ComboBoxItem Content="视频" />
                        <ComboBoxItem Content="直播" />
                    </ComboBox>
                    <TextBox Grid.Column="1" Text="{Binding VideoUrl}" Margin="8,0,0,0"
                             Classes="outlined"
                             PlaceholderText="视频地址 (mp4 / flv 等格式)"
                             FontSize="14" VerticalAlignment="Center" />
                </Grid>

                <!-- 音频地址 -->
                <TextBox Text="{Binding AudioUrl}"
                         Classes="outlined"
                         PlaceholderText="音频地址 (音视频分离时填写，否则留空)"
                         FontSize="14" VerticalAlignment="Center" />

                <!-- 视频名称 -->
                <TextBox Text="{Binding VideoName}"
                         Classes="outlined"
                         PlaceholderText="视频名称 (可选，默认为随机名称)"
                         FontSize="14" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                <Button Command="{Binding $parent[UserControl].((windows:MediaWindowViewModel)DataContext).ProcessMediaDownloadCommand}"
                        CommandParameter="{Binding}"
                        Classes="primary"
                        Width="140" Height="44"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <avalonia:MaterialIcon Kind="Download" Width="20" Height="20" />
                        <TextBlock Text="开始下载" FontSize="14" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
